@model List<BarberiaOnlineNueva.Models.Cita>

@{
    Layout = null;
    ViewData["Title"] = "Panel Barbero";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel Barbero</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="panel-page">
        <div class="overlay"></div>

        <div class="panel-card">
            <div class="panel-left">
                <img src="~/images/logo-barberia.png" alt="Logo Barbería" class="logo-barberia" />
                <h1>El Maestro Barberia</h1>
                <p>Consulta tus citas y tu actividad dentro del sistema.</p>
            </div>

            <div class="panel-right">
                <div class="panel-top">
                    <div>
                        <h2>Panel barbero</h2>
                        <p class="descripcion-panel">Accede a tus citas y a tu información de trabajo.</p>
                    </div>

                    <div class="panel-actions-top">
                        <a asp-controller="Cuenta" asp-action="Logout" class="btn-home btn-secundario">Cerrar sesión</a>
                    </div>
                </div>

                <!-- BOTONES -->
                <div class="panel-grid">

                    <a asp-controller="Barbero" asp-action="GestionarCitas" class="panel-box">
                        <h3>Gestionar citas</h3>
                        <p>Marca las citas como realizadas o canceladas.</p>
                    </a>

                    <a asp-controller="Home" asp-action="Index" class="panel-box">
                        <h3>Inicio</h3>
                        <p>Volver a la pantalla principal.</p>
                    </a>

                    <a asp-controller="Barbero" asp-action="Perfil" class="panel-box">
                        <h3>Mi perfil</h3>
                        <p>Edita tu información profesional.</p>
                    </a>

                </div>


                <!-- 🔥 AQUI VAN LAS CITAS -->
            <div class="panel-citas full-width">
                    <h3>Listado de citas</h3>

                    @if (!Model.Any())
                    {
                        <p>No tienes citas asignadas.</p>
                    }
                    else
                    {
                        <table class="tabla-citas">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Servicio</th>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                    <th>Estado</th>
                                    <th>Acciones</th> 
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var cita in Model)
                                {
                                    <tr>
                                        <td>@cita.NombreCliente</td>
                                        <td>@cita.NombreServicio</td>
                                        <td>@cita.Fecha.ToShortDateString()</td>
                                        <td>@cita.Hora</td>
                                        <td>@cita.Estado</td>

                                       
                                        <td>
                                            @if (cita.Estado == "Pendiente")
                                            {
                                                <a asp-controller="Cita"
                                                   asp-action="CambiarEstado"
                                                   asp-route-id="@cita.IdCita"
                                                   asp-route-estado="Realizada"
                                                   class="btn-accion btn-ok">
                                                    ✔
                                                </a>

                                                <a asp-controller="Cita"
                                                   asp-action="CambiarEstado"
                                                   asp-route-id="@cita.IdCita"
                                                   asp-route-estado="Cancelada"
                                                   class="btn-accion btn-cancel">
                                                    ✖
                                                </a>
                                            }
                                            else
                                            {
                                                <span style="color: gray;">Sin acciones</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

            </div>
        </div>
    </div>
</body>
</html>