@model BarberiaOnlineNueva.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <div class="login-page">
        <div class="login-card">

            <!-- IZQUIERDA -->
            <div class="login-left">
                <img src="~/images/logo-barberia.png" class="logo-barberia" />
                <h1>El Maestro Barberia</h1>
                <p>Tu estilo, nuestra pasión.</p>
            </div>

            <!-- DERECHA -->
            <div class="login-right">
                <h2>Crear cuenta</h2>
                <p>Regístrate para gestionar tus citas fácilmente.</p>

                <!-- VALIDACIONES -->
                @if (TempData["Error"] != null)
                {
                    <div class="mensaje-error">
                        @TempData["Error"]
                    </div>
                }

                @if (TempData["Exito"] != null)
                {
                    <div class="mensaje-exito">
                        @TempData["Exito"]
                    </div>
                }

                <form action="/Cuenta/Registro" method="post" class="registro-form">

                    <div class="input-group-custom">
                        <label>Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="input-group-custom">
                        <label>Correo</label>
                        <input asp-for="Correo" type="email" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="input-group-custom">
                        <label>Contraseña</label>
                        <input asp-for="Contrasena" type="password" class="form-control" />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login-main">
                        Registrarse
                    </button>

                </form>

                <div class="login-links">
                    <span>¿Ya tienes cuenta?</span>
                    <a href="/Cuenta/Login">Inicia sesión aquí</a>
                </div>

            </div>
        </div>
    </div>

    <!-- VALIDACIONES JS -->
    <partial name="_ValidationScriptsPartial" />

</body>
</html>